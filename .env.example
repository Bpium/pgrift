# Connection (URL preferred)
SOURCE_URL=postgresql://postgres:password@localhost:5432
TARGET_URL=postgresql://postgres:password@localhost:5432/tenants

# OR individual fields (used only if URL not set)
# SOURCE_HOST=localhost
# SOURCE_PORT=5432
# SOURCE_USER=postgres
# SOURCE_PASSWORD=
# TARGET_HOST=localhost
# TARGET_PORT=5432
# TARGET_USER=postgres
# TARGET_PASSWORD=
# TARGET_DATABASE=tenants

# Migration
# Option 1: filter source DBs by prefix (e.g. "bench_db_" to only migrate those)
FILTER_PREFIX=
# Option 2: provide a JSON file with an array of connection strings to migrate specific DBs
# Each entry: "postgresql://user:pass@host:port/dbname"
# When set, FILTER_PREFIX and SOURCE_URL are ignored for tenant discovery
# DB_LIST_FILE=./db-list.json
# SSL for all connections and pg_dump/psql (required for Yandex Cloud and other managed PG)
SSL=false
# Schema rename strategy:
#   "rewrite" (default) — dumps public schema as-is, rewrites references in the dump file.
#                         Does NOT modify the source DB. Works on managed platforms (Yandex Cloud, etc.)
#   "rename"            — renames public schema in source via ALTER SCHEMA, dumps, then rolls back.
#                         Requires the DB user to be the owner of the public schema.
# SCHEMA_RENAME_STRATEGY=rewrite
# After a successful dump, set the source database to read-only
# (ALTER DATABASE ... SET default_transaction_read_only = true).
# Useful during cutover to prevent new writes landing in the old DB.
# Requires the DB user to have ALTER DATABASE privilege (try/catch — never blocks migration).
# SOURCE_READONLY=false
# Database to connect to on the source server for tenant discovery (default: postgres)
# Required on managed platforms (e.g. Yandex Cloud) where the "postgres" database is not accessible
# SOURCE_DISCOVERY_DATABASE=some_existing_db
DUMP_DIR=/tmp/pg_migration_dumps
STATE_FILE=./migration-state.json
CONCURRENCY=10
# EXEC_TIMEOUT_MS=0   # 0 = no timeout (default). PostgreSQL-level timeouts are set via PGOPTIONS.
#                     # Set this only if you want a hard kill on hung pg_dump/psql processes.
# Maximum number of attempts per tenant before it is permanently skipped in this run.
# Tenants that reach this limit are reported in migration-report.json and can be retried
# by deleting their entry from migration-state.json and re-running.
MAX_RETRIES=3
# Dry-run mode: discover tenants and print what would be migrated without touching any data.
# DRY_RUN=false
# Skip checksum verification for tables with more than N rows (optional)
# SKIP_CHECKSUM_ABOVE_ROWS=100000

# Benchmark / script helpers
# Path to JSON array of DB or schema names (used by comparison, manyBases, manySchemas)
DB_LIST_PATH=./scripts/db-list.json
# Table name used by benchmark scripts (e.g. users_data)
BENCH_TABLE=users_data
# Column used as synthetic ID in benchmarks (e.g. dbId)
BENCH_ID_COLUMN=dbId
# Column used as name field in benchmarks (e.g. name)
BENCH_NAME_COLUMN=name

# createRandomDb script only
# CREATE_DB_COUNT=1000
# CREATE_DB_PREFIX=bench_db_
# CREATE_DB_PROJECT_PATH=

# ── Bpium integration (optional) ─────────────────────────────────────────────
# After each successful migration, sends a PATCH request to the Bpium admin API
# to update the $schema field of the corresponding record.
#
# Only active when BPIUM_API_BASE is set. All five vars must be provided together.
#
# DB_LIST_FILE must use the new { "id": <recordId>, "dbName": "<db>" } format
# for the Bpium update to be triggered (legacy connection-string format has no id).
#
# BPIUM_API_BASE=https://admin.bpium.ru
# BPIUM_CATALOG_ID=$companies
# BPIUM_LOGIN=admin@example.com
# BPIUM_PASSWORD=secret
# BPIUM_TIMEZONE_OFFSET=180
