# Connection string — preferred way (shorter and simpler)
SOURCE_URL=postgresql://postgres:password@localhost:5432
TARGET_URL=postgresql://postgres:password@localhost:5432/tenants

# OR individual fields (used only if URL is not set)
# SOURCE_HOST=localhost
# SOURCE_PORT=5432
# SOURCE_USER=postgres
# SOURCE_PASSWORD=
# TARGET_HOST=localhost
# TARGET_PORT=5432
# TARGET_USER=postgres
# TARGET_PASSWORD=
# TARGET_DATABASE=tenants

# Only migrate databases with this prefix (optional)
# Leave empty or remove to migrate everything
FILTER_PREFIX=db-

# Temporary directory for SQL dump files
DUMP_DIR=/tmp/pg_migration_dumps

# State file path (for resuming after failures)
STATE_FILE=./migration-state.json

# Number of tenants to process in parallel per batch
CONCURRENCY=10
